package main

import (
	"fmt"
	"time"
)

// function to print numbers
func printNumbers() {
	for i := 1; i <= 5; i++ {
		fmt.Println("Number:", i)
		time.Sleep(500 * time.Millisecond)
	}
}

// function to print alphabets
func printAlphabets() {
	for i := 'A'; i <= 'E'; i++ {
		fmt.Println("Alphabet:", string(i))
		time.Sleep(500 * time.Millisecond)
	}
}

func main() {
	// calling functions as goroutines
	go printNumbers()
	go printAlphabets()

	// wait so goroutines can finish
	time.Sleep(3 * time.Second)

	fmt.Println("Main function ends")
}
