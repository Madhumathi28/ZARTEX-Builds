# Start Redis
docker run -d -p 6379:6379 redis

# Open redis-cli
redis-cli

# Test your Lua script manually using EVAL
# Syntax: EVAL <script> <num_keys> <key> [args]
EVAL "
local tokens = tonumber(redis.call('GET', KEYS[1]) or 10)
if tokens > 0 then
  redis.call('SET', KEYS[1], tokens - 1)
  return {1, tokens - 1}
else
  return {0, 0}
end
" 1 "user:user-123"
